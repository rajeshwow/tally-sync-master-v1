PORT=5050
TALLY_URL=http://localhost:9000


#CRM_BASE_URL=https://flexloud-api.onrender.com/v1
CRM_BASE_URL=https://crm-api.flexloud.com/v1
CRM_TENANT_SLUG=atvi
TALLY_AGENT_TOKEN=a8f4b8e2c3d9f1a09b7c6d5e4f1234567890abcdef1234567890abcdef12
SYNC_CRON=*/30 * * * *
TALLY_COMPANIES=Atvi
CRM_REQUEST_TIMEOUT_MS=600000
DISABLE_AUTO_SYNC=false
# Masters (ek baar sync hote hain)
BATCH_SIZE_LEDGERS=10
BATCH_SIZE_STOCK_ITEMS=10
BATCH_SIZE_COST_CENTERS=10

# Transactions (413 wale — inhe kam rakho)
BATCH_SIZE_SALES_ORDERS=5
BATCH_SIZE_PURCHASE_ORDERS=5
BATCH_SIZE_OUTSTANDINGS=5
 
 # Historical sync smart start
HISTORICAL_SYNC_AUTO_DETECT_FROM_DATE=true
HISTORICAL_SYNC_MIN_YEAR=2022
HISTORICAL_SYNC_DETECT_CHUNK_MONTHS=12
HISTORICAL_SYNC_RANGE_MONTHS=1
HISTORICAL_TRANSACTION_RANGE_MONTHS=1
TALLY_RETRY_ATTEMPTS=3
TALLY_REQUEST_TIMEOUT_MS=300000
OUTSTANDING_REPORT_FILTER_TO_DATE=false



# Automatic daily sync
DAILY_SYNC_ENABLED=true
DAILY_SYNC_RUN_ON_START=true

# Every 30 minutes
SYNC_INTERVAL_MINUTES=30

# Pull previous 3 days on every daily sync
DAILY_SYNC_LOOKBACK_DAYS=5

# Wait for Tally if agent starts before Tally
DAILY_SYNC_STARTUP_POLL_SECONDS=30
DAILY_SYNC_STARTUP_MAX_WAIT_MINUTES=0

TALLY_DELIVERY_CHALLAN_VOUCHER_TYPES=Challan Material,Delivery Note
BATCH_SIZE_DELIVERY_CHALLANS=5